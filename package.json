{
  "name": "@mjakl/pi-subagent",
  "version": "2.1.0-local.0",
  "description": "Subagent extension for Pi coding agent. Delegate tasks to specialized agents. Local editable fork.",
  "type": "module",
  "main": "index.ts",
  "files": [
    "index.ts",
    "subagent-config.ts",
    "agents.ts",
    "runner.ts",
    "runner-cli.js",
    "runner-events.js",
    "pane-renderer.js",
    "pane-renderer-core.js",
    "pane-renderer-core.ts",
    "provider-auth.ts",
    "project-agent-paths.ts",
    "project-trust.ts",
    "render.ts",
    "chain-helpers.ts",
    "metadata-frontmatter.ts",
    "runner-core.ts",
    "trust-path.ts",
    "types.ts",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "test": "bun test --pass-with-no-tests",
    "check": "bunx tsc --noEmit",
    "ci": "bun run check && bun test --pass-with-no-tests"
  },
  "keywords": [
    "pi",
    "subagent",
    "delegation",
    "pi-package"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.2.3",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-agent-core": {
      "optional": true
    },
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-tui": {
      "optional": true
    },
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  },
  "private": true,
  "packageManager": "bun@1.3.14"
}
